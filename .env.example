# ── Server ──────────────────────────────────────────────────────────────────
PORT=3000
# Full public URL used for QR code generation (no trailing slash).
# Leave blank to auto-detect from the request host.
BASE_URL = https://charity-poll.onrender.com

# ── Admin ────────────────────────────────────────────────────────────────────
ADMIN_PASSWORD=charity2026

# ── Event branding ───────────────────────────────────────────────────────────
EVENT_NAME=Hope Gala 2026
EVENT_TAGLINE=Together we make a difference
# URL or absolute path to a logo image (leave blank to hide)
LOGO_URL=

# Hex color values
PRIMARY_COLOR=#e85d04
ACCENT_COLOR=#f48c06
BG_COLOR=#fff8f0
DARK_COLOR=#2d3250

# ── Google OAuth (required for Gmail login on the join page) ─────────────────
# Create credentials at https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI must include: https://your-domain.com/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Full callback URL — defaults to BASE_URL + /auth/google/callback if left blank
GOOGLE_CALLBACK_URL=

# Session secret — set a long random string in production
SESSION_SECRET=change-me-to-a-long-random-string

# ── Persistence ──────────────────────────────────────────────────────────────
# MongoDB connection string (recommended for production — survives redeploys).
# Get a free URI from https://www.mongodb.com/atlas
# Leave blank to fall back to the local JSON file below.
MONGODB_URI=

# Local file fallback (used when MONGODB_URI is not set)
SESSION_PATH=./session.json
